@page "/radar"
@rendermode InteractiveServer
@implements IDisposable

<div style="background-color:black;width:800px;height:450px;border:2px solid lime">

    <svg width="800" height="450">

        <!-- Outer Ring -->
        <path d="M100 400 A300 300 0 0 1 700 400"
              stroke="lime"
              stroke-width="1"
              fill="none" />

        <!-- Middle Ring -->
        <path d="M200 400 A200 200 0 0 1 600 400"
              stroke="lime"
              stroke-width="1"
              fill="none" />

        <!-- Inner Ring -->
        <path d="M300 400 A100 100 0 0 1 500 400"
              stroke="lime"
              stroke-width="1"
              fill="none" />

        <!-- Ground Line -->

        <line x1="100"
              y1="400"
              x2="700"
              y2="400"
              stroke="lime"
              stroke-width="1" />

        <!-- Centre Line -->

        <line x1="400"
              y1="100"
              x2="400"
              y2="400"
              stroke="lime"
              stroke-width="1" />

        <!-- Sweep -->

        <line x1="@CentreX"
              y1="@CentreY"
              x2="@SweepX"
              y2="@SweepY"
              stroke="lime"
              stroke-width="2" />

        <!-- Radar points -->
        @foreach (var point in Points)
        {
            <circle cx="@point.X"
                    cy="@point.Y"
                    r="3"
                    fill="lime" />
        }

        <!-- Robot -->

        <circle cx="@CentreX"
                cy="@CentreY"
                r="8"
                fill="red" />

    </svg>

</div>

<h4 style="color:lime">
    Sweep Angle : @SweepAngle
</h4>

@code
{
    private Timer? timer;

    private const double CentreX = 400;
    private const double CentreY = 400;
    private const double Radius = 300;

    private double SweepAngle = 180;

    private bool MovingRight = false;

    public record RadarPoint(double X, double Y, DateTime TimeStamp);

    private readonly List<RadarPoint> Points = new();

    private double SweepX =>
        CentreX + Radius * Math.Cos(SweepAngle * Math.PI / 180);

    private double SweepY =>
        CentreY - Radius * Math.Sin(SweepAngle * Math.PI / 180);

    protected override void OnInitialized()
    {
        timer = new Timer(UpdateRadar, null, 0, 50);
    }

    private void UpdateRadar(object? state)
    {
        if (MovingRight)
        {
            SweepAngle += 2;

            if (SweepAngle >= 180)
                MovingRight = false;
        }
        else
        {
            SweepAngle -= 2;

            if (SweepAngle <= 0)
                MovingRight = true;
        }

        // Fake point

        double distance = 100 + Random.Shared.NextDouble() * 180;

        double radians = SweepAngle * Math.PI / 180;

        double x = CentreX + distance * Math.Cos(radians);

        double y = CentreY - distance * Math.Sin(radians);

        lock (Points)
        {
            Points.Add(new RadarPoint(x, y, DateTime.Now));

            Points.RemoveAll(p =>
                DateTime.Now - p.TimeStamp >
                TimeSpan.FromSeconds(2));
        }

        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}